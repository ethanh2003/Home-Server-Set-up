networks:
  proxy_net:
    external: true

services:
  # 1. The Notification Hub (Ntfy)
  # Acts as a receiver for all alerts.
  ntfy:
    image: binwiederhier/ntfy:v2.11.0
    container_name: ntfy
    command:
      - serve
    environment:
      - UID=1000
      - GID=1000
      - NTFY_BASE_URL=http://192.168.1.113:8099
      - NTFY_CACHE_FILE=/var/cache/ntfy/cache.db
      - NTFY_AUTH_DEFAULT_ACCESS=deny-all
    volumes:
      - /home/ethan/docker/ntfy/cache:/var/cache/ntfy
      - /home/ethan/docker/ntfy/config:/etc/ntfy
    ports:
      - 8099:80
    restart: unless-stopped
    networks:
      - proxy_net

  # 2. Service Monitor (Uptime Kuma)
  # Polling interval: Set to 60s+ to save N150 CPU cycles.
  uptime-kuma:
    image: louislam/uptime-kuma:1
    container_name: uptime-kuma
    volumes:
      - /home/ethan/docker/uptime-kuma:/app/data
      - /var/run/docker.sock:/var/run/docker.sock:ro # Access to monitor Docker state directly
    ports:
      - 3001:3001
    depends_on:
      - ntfy
    restart: unless-stopped
    networks:
      - proxy_net

  # 3. Update Notifier (Diun)
  # Checks for updates every 6h. Does NOT auto-update (Critical for USB stability).
  diun:
    image: crazymax/diun:latest
    container_name: diun
    command: serve
    volumes:
      - /home/ethan/docker/diun:/data
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      - PUID=1000
      - PGID=1000
      - "TZ=America/New_York"
      - "DIUN_WATCH_WORKERS=5" # Low worker count for N150
      - "DIUN_WATCH_SCHEDULE=0 */6 * * *" # Check every 6 hours
      - "DIUN_PROVIDERS_DOCKER=true"
      # Updated to use the container name on the shared network, or localhost if side-car (but they are separate services)
      # Since they are on the same network 'ntfy' resolves correctly.
      - "DIUN_NOTIF_NTFY_ENDPOINT=http://ntfy:80"
      - "DIUN_NOTIF_NTFY_TOPIC=updates_topic" 
    restart: unless-stopped
    networks:
      - proxy_net
