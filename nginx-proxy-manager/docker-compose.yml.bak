services:
  npm:
    image: 'jc21/nginx-proxy-manager:latest'
    container_name: npm
    restart: unless-stopped
    ports:
      - '80:80'    # Internal HTTP
      - '81:81'    # Admin Interface
      - '443:443'  # Internal HTTPS
    volumes:
      - /home/ethan/docker/nginx_config/data:/data
      - /home/ethan/docker/nginx_config/letsencrypt:/etc/letsencrypt
    networks:
      - proxy_net

networks:
  proxy_net:
    external: true
