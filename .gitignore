# OS / System
.DS_Store
Thumbs.db

# Global Ignore Patterns for Configuration & Data
# Matches any directory ending in _config, _data, _db at root or sub-levels
*_config/
*_data/
*_db/

# Matches standard config/data directory names inside service folders
*/config/
*/data/
*/database/
*/db/
*/appdata/
*/metadata/

# Specific Directories (Legacy or irregular names)
portainer_data/
grafana_provisioning/
.db_dumps/
downloads/
*/downloads/
temp/
*/temp/

# Environment Variables & Secrets
.env
*.env
secrets.yaml
*.key
*.pem
*.crt

# Database Files
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# Logs & Temporary Files
*.log
logs/
*/logs/
*.pid
*.bak
*.lock
__pycache__/
*.pyc
.cache/
*/.cache/
.gemini/
gha-creds-*.json
